# =============================================================================
# traderj Environment Configuration
# Copy this to .env and fill in your values
# =============================================================================

# --- Database ---
# DB_TYPE: "sqlite" (기본, 설치 불필요) 또는 "postgres" (TimescaleDB 사용 시)
DB_TYPE=sqlite
DB_SQLITE_PATH=traderj.db

# --- PostgreSQL (DB_TYPE=postgres 일 때만) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=traderj
# DB_USER=traderj
# DB_PASSWORD=changeme
# DB_POOL_MIN=2
# DB_POOL_MAX=10

# --- Exchange (Upbit) ---
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# --- API Server ---
TRADERJ_API_KEY=changeme-api-key
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Trading ---
TRADING_MODE=paper
TRADING_SYMBOL=BTC/KRW
INITIAL_PAPER_KRW=10000000

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Monitoring ---
PROMETHEUS_PORT=8001
GRAFANA_PASSWORD=admin

# --- Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/v1/stream

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
